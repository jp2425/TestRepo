{
  "name": "py-installer-action",
  "version": "1.0.0",
  "description": "GitHub Action that downloads a zip and installs the Python package inside it",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js --license licenses.txt --minify",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1"
  },
  "license": "MIT"
}
